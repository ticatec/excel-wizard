{
  "name": "@ticatec/excel-wizard",
  "version": "0.3.0",
  "description": "A schema-driven Svelte component library for Excel batch data processing with wizard-style interfaces, supporting validation, encoding, and template generation.",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && svelte-package",
    "package": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "preview": "vite preview",
    "publish:public": "npm run build && npm publish --access public"
  },
  "keywords": [
    "excel",
    "xlsx",
    "svelte",
    "component",
    "batch",
    "upload",
    "schema",
    "wizard",
    "data-processing",
    "validation",
    "template",
    "dropdown",
    "exceljs",
    "i18n",
    "import-export"
  ],
  "files": [
    "dist",
    "documents",
    "!dist/**/*.scss",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "dist/index.js",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "svelte": "./dist/index.js"
    },
    "./BaseTemplate": {
      "types": "./dist/BaseTemplate.d.ts",
      "import": "./dist/BaseTemplate.js"
    },
    "./BaseUploadTemplate": {
      "types": "./dist/BaseUploadTemplate.d.ts",
      "import": "./dist/BaseUploadTemplate.js"
    },
    "./BaseEncodingTemplate": {
      "types": "./dist/BaseEncodingTemplate.d.ts",
      "import": "./dist/BaseEncodingTemplate.js"
    },
    "./SchemaUploadTemplate": {
      "types": "./dist/SchemaUploadTemplate.d.ts",
      "import": "./dist/SchemaUploadTemplate.js"
    },
    "./SchemaEncodingTemplate": {
      "types": "./dist/SchemaEncodingTemplate.d.ts",
      "import": "./dist/SchemaEncodingTemplate.js"
    },
    "./SchemaExporter": {
      "types": "./dist/SchemaExporter.d.ts",
      "import": "./dist/SchemaExporter.js"
    },
    "./DataColumn": {
      "types": "./dist/DataColumn.d.ts",
      "import": "./dist/DataColumn.js"
    },
    "./FileUploadWizard": {
      "types": "./dist/FileUploadWizard.svelte.d.ts",
      "import": "./dist/FileUploadWizard.svelte",
      "svelte": "./dist/FileUploadWizard.svelte"
    },
    "./EncodingWizard": {
      "types": "./dist/EncodingWizard.svelte.d.ts",
      "import": "./dist/EncodingWizard.svelte",
      "svelte": "./dist/EncodingWizard.svelte"
    },
    "./SheetPickupDialog": {
      "types": "./dist/SheetPickupDialog.svelte.d.ts",
      "import": "./dist/SheetPickupDialog.svelte",
      "svelte": "./dist/SheetPickupDialog.svelte"
    },
    "./SheetNameViewRender": {
      "types": "./dist/SheetNameViewRender.svelte.d.ts",
      "import": "./dist/SheetNameViewRender.svelte",
      "svelte": "./dist/SheetNameViewRender.svelte"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@ticatec/i18n": "^0.2.4",
    "@ticatec/uniface-element": "^0.3.18",
    "@ticatec/uniface-google-material-icons": "^0.1.8",
    "dayjs": "^1.11.10",
    "exceljs": "^4.4.0",
    "publint": "^0.3.2",
    "sass": "^1.57.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.0.0",
    "svelte-portal": "^2.2.1",
    "svelte-preprocess": "^6.0.3",
    "tslib": "^2.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  },
  "author": "Henry Feng <huili.f@gmail.com>",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ticatec/excel-wizard.git"
  },
  "bugs": {
    "url": "https://github.com/ticatec/excel-wizard/issues"
  },
  "homepage": "https://github.com/ticatec/excel-wizard#readme"
}